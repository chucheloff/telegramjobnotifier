# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Target channel IDs (comma-separated, use negative IDs)
CHANNEL_IDS=-1001234567890

# Admin Telegram User IDs (comma-separated)
ADMIN_IDS=123456789

# Optional: Text wrapper prefix
WRAPPER_PREFIX=[Posted via Telegram Job Notifier]

# Optional: Text wrapper suffix
WRAPPER_SUFFIX=
